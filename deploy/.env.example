# Copy to `deploy/.env` before running docker compose

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=example-anon-key

# web3forms
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# Google Analytics
NEXT_PUBLIC_GA_ID=G-xxxxxxxxxx

# GitHub latest release API URL (optional)
NEXT_PUBLIC_GITHUB_LATEST_RELEASE_URL=

# Feishu bot webhook (required for fund daily alerts)
FEISHU_WEBHOOK_URL=

# Fund alert worker runtime
ALERT_TIMEZONE=Asia/Shanghai
ENABLE_ALERT_WORKER=true

# Postgres runtime
POSTGRES_DB=fund_alert
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/fund_alert

# Web service host port
WEB_PORT=38080
